{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": ".test-dist",
    "rootDir": ".",
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2022",
    "lib": ["es2022"],
    "types": ["node"],
    "isolatedModules": false,
    "incremental": false,
    "plugins": []
  },
  "include": ["tests/**/*.test.ts"],
  "exclude": ["node_modules", "mcp-servers", ".next"]
}
