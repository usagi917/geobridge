# 国交省 Geospatial MCP（不動産情報ライブラリ API キー）
MLIT_GEOSPATIAL_API_KEY=
# TLS 検証を明示的に無効化したい場合のみ true
MLIT_GEOSPATIAL_SKIP_SSL_VERIFY=false
# Geospatial はレスポンスが重いので専用タイムアウトを分ける
MLIT_GEOSPATIAL_MULTI_API_TIMEOUT_MS=40000
MLIT_GEOSPATIAL_LAND_PRICE_TIMEOUT_MS=20000
MLIT_LAND_PRICE_HISTORY_CONCURRENCY=2

# 国交省 DPF MCP（データプラットフォーム API キー）
MLIT_DPF_API_KEY=

# Ollama 設定
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:35b-a3b

# OpenAI フォールバック（任意）
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5-nano
OPENAI_REASONING_EFFORT=low
OPENAI_VERBOSITY=low
OPENAI_TIMEOUT_MS=60000
OPENAI_MAX_TOKENS=1536
OPENAI_API_KEY=

# city2graph 設定（任意）
# CITY2GRAPH_ENABLED=false で無効化
CITY2GRAPH_ENABLED=true
CITY2GRAPH_TIMEOUT_MS=120000
